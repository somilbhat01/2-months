#include <iostream>
using namespace std;

class StackArray {
private:
    static const int MAX_SIZE = 100;
    int arr[MAX_SIZE];
    int topIndex;
    
public:
    StackArray() : topIndex(-1) {}
    
    void push(int value) {
        if (topIndex >= MAX_SIZE - 1) {
            cout << "Error: Stack overflow!\n";
            return;
        }
        arr[++topIndex] = value;
    }
    
    void pop() {
        if (isEmpty()) {
            cout << "Error: Stack empty! Cannot pop.\n";
            return;
        }
        topIndex--;
    }
    
    int top() {
        if (isEmpty()) {
            cout << "Error: Stack empty! No top element.\n";
            return -1;
        }
        return arr[topIndex];
    }
    
    bool isEmpty() {
        return topIndex == -1;
    }
    
    int size() {
        return topIndex + 1;
    }
    
    void display() {
        if (isEmpty()) {
            cout << "Stack is empty\n";
            return;
        }
        cout << "Stack (top to bottom): ";
        for (int i = topIndex; i >= 0; i--) {
            cout << arr[i] << " ";
        }
        cout << endl;
    }
};
